#!/usr/bin/env bash
# escli wrapper — runs escli-rs using the local binary when available,
# and falls back to Docker if not.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
set -a && set +u && source "${SCRIPT_DIR}/.env.sh" && set -u && set +a

# ── Prefer the local binary (much faster than Docker) ─────────────────────────
BINARY="${SCRIPT_DIR}/escli-bin"

if [ -f "$BINARY" ] && [ -x "$BINARY" ]; then
    exec "$BINARY" "$@"
fi

# ── Fallback: Docker ──────────────────────────────────────────────────────────
case "$(uname -m)" in
    arm64|aarch64) IMAGE="ghcr.io/anaethelion/escli:latest-arm64" ;;
    x86_64)        IMAGE="ghcr.io/anaethelion/escli:latest-amd64" ;;
    *)             echo "Unsupported architecture: $(uname -m)" >&2; exit 1 ;;
esac

docker run --network host -i --rm \
  -e ESCLI_URL \
  -e ESCLI_API_KEY \
  "$IMAGE" "$@"
