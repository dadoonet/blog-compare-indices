# Elasticsearch connection credentials.
# Copy this file to .env.es and fill in the values.
# .env.es is NOT committed — it contains secrets.
# When using start-local, setup.sh populates .env.es automatically.

ESCLI_URL=http://localhost:9200
ESCLI_API_KEY=
# Alternative: basic auth — uncomment if not using an API key
#ESCLI_USERNAME=elastic
#ESCLI_PASSWORD=
